CERTWARDEN_BASE_URL="https://certwarden.example.com"
CERTWARDEN_CERT_NAME="dns.example.com"
CERTWARDEN_CERT_API_KEY="replace-me"
CERTWARDEN_KEY_API_KEY="replace-me"
TECHNITIUM_API_URL="http://127.0.0.1:5380"
TECHNITIUM_API_TOKEN="replace-me"
TECHNITIUM_SERVICE="dns.service"
TECHNITIUM_TLS_TARGETS="web,dns"
TECHNITIUM_PFX_PATH="/etc/dns/certwarden/technitium.pfx"
TECHNITIUM_PFX_PASSWORD="replace-with-a-local-pfx-password"
TECHNITIUM_CERT_OWNER="root:root"